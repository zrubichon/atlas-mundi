{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/generate.js": {
      "maxDuration": 60
    },
    "api/daily-update.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/daily-update",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
